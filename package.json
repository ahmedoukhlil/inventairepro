{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build && npm run build:pwa",
        "build:pwa": "tailwindcss -i resources/css/pwa.css -o public/pwa/tailwind.css --minify",
        "watch:pwa": "tailwindcss -i resources/css/pwa.css -o public/pwa/tailwind.css --watch",
        "dev": "vite"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.2.4",
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "jsbarcode": "^3.12.3"
    }
}
